{
  "name": "petx",
  "version": "0.1.0",
  "private": true,
  "description": "Framework renderers for Codex pet spritesheet atlases.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "keywords": [
    "codex-pet",
    "spritesheet",
    "pixel-art",
    "react",
    "react-native",
    "vue",
    "svelte",
    "solid",
    "web-components"
  ],
  "homepage": "https://github.com/IchenDEV/petx#readme",
  "bugs": {
    "url": "https://github.com/IchenDEV/petx/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IchenDEV/petx.git"
  },
  "scripts": {
    "dev": "pnpm --filter @petx/example-react dev",
    "dev:site": "pnpm --filter @petx/example-react dev",
    "dev:example:react": "pnpm --filter @petx/example-react dev",
    "dev:example:vue": "pnpm --filter @petx/example-vue dev",
    "dev:example:svelte": "pnpm --filter @petx/example-svelte dev",
    "dev:example:solid": "pnpm --filter @petx/example-solid dev",
    "dev:example:webcomponent": "pnpm --filter @petx/example-webcomponent dev",
    "build:packages": "pnpm -r --filter @petx/core --filter @petx/react --filter @petx/react-native --filter @petx/vue --filter @petx/svelte --filter @petx/solid --filter @petx/webcomponent run build",
    "build": "pnpm -r run build",
    "typecheck:packages": "pnpm -r --filter @petx/core --filter @petx/react --filter @petx/react-native --filter @petx/vue --filter @petx/svelte --filter @petx/solid --filter @petx/webcomponent run typecheck",
    "typecheck": "pnpm -r run typecheck",
    "pack:check": "pnpm run build:packages && pnpm -r --filter @petx/core --filter @petx/react --filter @petx/react-native --filter @petx/vue --filter @petx/svelte --filter @petx/solid --filter @petx/webcomponent pack --dry-run --json",
    "pack:tarballs": "mkdir -p npm-packages && pnpm run build:packages && pnpm -r --filter @petx/core --filter @petx/react --filter @petx/react-native --filter @petx/vue --filter @petx/svelte --filter @petx/solid --filter @petx/webcomponent pack --pack-destination npm-packages",
    "publish:dry-run": "pnpm run build:packages && pnpm -r --filter @petx/core --filter @petx/react --filter @petx/react-native --filter @petx/vue --filter @petx/svelte --filter @petx/solid --filter @petx/webcomponent publish --dry-run --access public",
    "publish:packages": "pnpm run build:packages && pnpm -r --filter @petx/core --filter @petx/react --filter @petx/react-native --filter @petx/vue --filter @petx/svelte --filter @petx/solid --filter @petx/webcomponent publish --access public",
    "test": "pnpm run typecheck && pnpm run build && node --test tests/*.test.mjs"
  },
  "devDependencies": {
    "@petx/core": "workspace:*",
    "@petx/react": "workspace:*",
    "@petx/react-native": "workspace:*",
    "@petx/solid": "workspace:*",
    "@petx/svelte": "workspace:*",
    "@petx/vue": "workspace:*",
    "@petx/webcomponent": "workspace:*",
    "@sveltejs/vite-plugin-svelte": "^6.2.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vite-plugin-solid": "^2.11.8",
    "vue": "^3.5.33"
  }
}
