{
  "name": "@petx/core",
  "version": "0.1.0",
  "description": "Shared frame math, types, and CSS variable helpers for Codex pet atlases.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "codex-pet",
    "spritesheet",
    "atlas",
    "animation"
  ],
  "homepage": "https://github.com/IchenDEV/petx#readme",
  "bugs": {
    "url": "https://github.com/IchenDEV/petx/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IchenDEV/petx.git",
    "directory": "packages/core"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
